<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مشروع الأرتيميا الذكي | محمد علي براء</title>
    <style>
        :root { --primary: #00d4ff; --accent: #ffd1a4; }
        body { margin: 0; background: #000; color: white; font-family: -apple-system, system-ui, sans-serif; overflow: hidden; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: space-between; }
        
        /* الهيدر العلوي */
        .header { margin-top: 40px; text-align: center; z-index: 10; }
        .school-tag { background: rgba(0, 212, 255, 0.1); color: var(--primary); padding: 8px 25px; border-radius: 50px; font-weight: bold; border: 1px solid var(--primary); font-size: 0.85rem; }

        /* منطقة العرض المركزية */
        .artemia-view { flex: 1; display: flex; align-items: center; justify-content: center; position: relative; width: 100%; }
        .glow { position: absolute; width: 250px; height: 250px; background: var(--primary); filter: blur(100px); opacity: 0.2; border-radius: 50%; }
        
        /* أيقونة الأرتيميا العلمية - مرسومة برمجياً لضمان الظهور */
        .artemia-svg { width: 180px; height: 180px; z-index: 5; animation: pulse 3s infinite ease-in-out; }
        @keyframes pulse { 0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px var(--primary)); } 50% { transform: scale(1.1); filter: drop-shadow(0 0 30px var(--primary)); } }

        /* البطاقة السفلية الفاخرة */
        .main-card {
            width: 90%; max-width: 450px; margin-bottom: 40px;
            background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-radius: 35px; padding: 25px; text-align: center;
        }
        
        .name-label { font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 2px; }
        h1 { margin: 10px 0; font-size: 1.85rem; font-weight: 800; background: linear-gradient(180deg, #fff 0%, #888 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        .separator { height: 1px; background: rgba(255,255,255,0.1); margin: 20px 0; }
        
        .supervisors { display: flex; flex-direction: column; gap: 10px; }
        .sup-title { color: var(--primary); font-size: 0.85rem; font-weight: bold; }
        .sup-names { font-size: 0.95rem; color: #ccc; display: flex; justify-content: center; gap: 15px; }
    </style>
</head>
<body>

    <div class="header">
        <div class="school-tag">ثانوية الذرى للمتميزين - كربلاء</div>
    </div>

    <div class="artemia-view">
        <div class="glow"></div>
        <svg class="artemia-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C10 2 8 4 8 8C8 10 9 12 10 14V20C10 21.1 10.9 22 12 22C13.1 22 14 21.1 14 20V14C15 12 16 10 16 8C16 4 14 2 12 2Z" fill="#00d4ff" fill-opacity="0.8"/>
            <path d="M7 7L4 6M7 10L3 10M7 13L4 14M17 7L20 6M17 10L21 10M17 13L20 14" stroke="#00d4ff" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
    </div>

    <div class="main-card">
        <p class="name-label">المبرمج الموهوب</p>
        <h1>محمد علي براء صاحب</h1>
        
        <div class="separator"></div>
        
        <div class="supervisors">
            <span class="sup-title">بإشراف الأساتذة الأفاضل</span>
            <div class="sup-names">
                <span>خالد النصراوي</span>
                <span>حامد النصراوي</span>
                <span>علي غصن</span>
            </div>
        </div>
    </div>

</body>
</html>
